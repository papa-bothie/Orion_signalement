# Variables d'environnement pour orion-mobile

# ⚠️ ATTENTION : L'application mobile (sur téléphone/émulateur) ne peut pas communiquer 
# avec "localhost". Vous devez INSERER l'adresse IP locale de votre ordinateur ci-dessous.
# Exemples : 192.168.1.50, 10.0.0.150, etc.

# Pour connaitre votre IP sous Linux, ouvrez un terminal et tapez : hostname -I

EXPO_PUBLIC_API_URL=http://192.168.1.15:3000/api/v1
EXPO_PUBLIC_SOCKET_URL=http://192.168.1.15:3000

# Environnement (development ou production)
EXPO_PUBLIC_APP_ENV=development
